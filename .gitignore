# Compiled binaries / build output
bin/
dist/
*.exe
*.dll
*.so
*.dylib
# Top-level dev build artifacts (`go build ./cmd/...` drops these at the repo root)
/ironctl
/controlplane

# Go
*.test
*.out
/vendor/
go.work.sum

# Local env / secrets — never commit
.env
deploy/.env.prod
*.local
*.key
*.pem

# OS / editor cruft
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
.bin/*
# gstack browse session cache
.gstack/

# Local agent / session state — never commit
.claude/
.remember/

# live-containment --share receipt output (per-run, regenerated)
ironclaw-receipt/

# Example runtime deps (created by an example's run.sh; never committed)
node_modules/
.venv/

# Docs site build artifacts (MkDocs)
/site/
_site/
docs/reference/openapi.yaml
__pycache__/
